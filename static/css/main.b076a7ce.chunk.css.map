.header {
  display: flex;
  align-items: center;
  padding: 10px 16px;
  background-color: #f0f2f5;
  border-bottom: 1px solid #e0e0e0;
  height: 60px;
}

.header__avatar {
  width: 40px;
  height: 40px;
  margin-right: 15px;
}
.header__avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}
.header__info {
  flex: 1;
}
.header__name {
  font-weight: 500;
  font-size: 16px;
  color: #111b21;
}
.header__status {
  font-size: 13px;
  color: #667781;
}
.header__placeholder {
  color: #667781;
  padding: 20px;
  text-align: center;
}
